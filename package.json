{
  "name": "@sourceregistry/semantic-release-jsr",
  "description": "semantic-release plugin to publish a package to JSR",
  "version": "0.0.0",
  "author": "SourceRegistry",
  "bugs": {
    "url": "https://github.com/SourceRegistry/semantic-release-jsr/issues"
  },
  "dependencies": {
    "@semantic-release/error": "^4.0.0",
    "aggregate-error": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "jsr": "^0.13.4",
    "read-pkg": "^10.0.0"
  },
  "devDependencies": {
    "c8": "11.0.0",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3"
  },
  "engines": {
    "node": "^22.14.0 || >= 24.10.0"
  },
  "files": [
    "lib",
    "index.js"
  ],
  "homepage": "https://github.com/SourceRegistry/semantic-release-jsr#readme",
  "keywords": [
    "jsr",
    "publish",
    "semantic-release",
    "deno"
  ],
  "license": "MIT",
  "main": "./index.js",
  "exports": "./index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "c8": {
    "include": [
      "lib/**/*.js",
      "index.js"
    ],
    "reporter": [
      "json",
      "text",
      "html"
    ],
    "all": true
  },
  "peerDependencies": {
    "semantic-release": ">=20.1.0"
  },
  "prettier": {
    "printWidth": 120,
    "trailingComma": "es5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SourceRegistry/semantic-release-jsr.git"
  },
  "scripts": {
    "lint": "prettier --check \"{lib,test}/**/*.{js,json,ts}\" \"*.{md,json,js}\" \".github/**/*.yml\"",
    "lint:prettier": "prettier --check \"{lib,test}/**/*.{js,json,ts}\" \"*.{md,json,js}\" \".github/**/*.yml\"",
    "lint:prettier:fix": "prettier --write \"*.{js,json,md}\" \".github/**/*.{md,yml}\" \"{lib,test}/**/*.js\"",
    "test": "npm run lint:prettier && npm run test:unit",
    "test:unit": "c8 node --test"
  },
  "type": "module",
  "packageManager": "npm@11.12.1"
}
